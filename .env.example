# seo-agent — per-project config.
# Copy this to <your-project>/.claude/seo/.env and fill in. Never commit the real file.

# ── Google Search Console (service account) ────────────────────────────────
# See SETUP.md for how to create the service account ("the user") and grant it
# access. Provide the key EITHER inline (one line) OR as a file path (resolved
# relative to this .env). The file form is cleaner — drop the JSON next to this
# file and reference it by name.
GSC_SERVICE_ACCOUNT_KEY_FILE=service-account.json
# GSC_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# The exact Search Console property. Domain properties use the sc-domain: form;
# URL-prefix properties use the full origin with trailing slash.
GSC_SITE_URL=https://example.com/
# GSC_SITE_URL=sc-domain:example.com
# Optional override for submit-sitemap.ts (defaults to <site origin>/sitemap.xml)
# GSC_SITEMAP_URL=https://example.com/sitemap_index.xml

# ── Google Analytics 4 ─────────────────────────────────────────────────────
# Same service account works — just enable the "Google Analytics Data API" and
# add the service-account email as a Viewer in GA4 Admin → Property Access.
# Property ID is the numeric id from GA4 Admin → Property Settings.
GA4_PROPERTY_ID=properties/123456789

# ── DataForSEO (optional — keyword/SERP/competitor research) ───────────────
# Get from https://app.dataforseo.com/api-access
# DATAFORSEO_LOGIN=you@example.com
# DATAFORSEO_PASSWORD=your-api-password

# Response cache (DataForSEO is pay-per-request; identical re-runs are free)
# SEO_CACHE_TTL=604800     # seconds (default 7 days)
# SEO_NO_CACHE=1           # disable the cache (or pass --no-cache to any script)
# SEO_CACHE_VERBOSE=0      # silence the [cache]/[live] stderr lines
# SEO_REQUEST_TIMEOUT=180  # per-request timeout, seconds

# ── Niche / scoring tuning (optional) — see scripts/seo-config.ts ──────────
# SEO_DEFAULT_LOCATION=2840            # 2840=US, 2826=UK, 2643=Russia
# SEO_DEFAULT_LANG=en
# SEO_DEMAND_MIN_VOLUME=500            # min monthly volume to pass the demand gate
# SEO_STRONG_DOMAINS=tripadvisor.com,lonelyplanet.com,booking.com   # your vertical's authorities
# SEO_STRONG_DOMAINS_REPLACE=1         # use ONLY the env list (don't extend defaults)
# SEO_ENFORCE_FIT=1                    # require catalog-fit classification to pass scoring
# SEO_TIMING_SWEETSPOT_WEEKS=8
# SEO_TIMING_SWEETSPOT_MULT=2.0
# SEO_OUTPUT_DIR=agents-info/seo/scored

# ── Optional: internal site SEO API ────────────────────────────────────────
# SEO_API_URL=http://localhost:3001/api/seo
# SEO_API_TOKEN=your-token
